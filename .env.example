# Copy this to .env and fill in your values
# .env is gitignored — never commit it

# ── GCP ──────────────────────────────────────────────────────────
GCP_PROJECT_ID=matan-app-zoo
GCP_REGION=us-central1

# ── Auth ─────────────────────────────────────────────────────────
# Your app password — enter this in the app on first launch
# Make it strong, keep it secret, never commit it
MASTER_KEY=your-secret-access-code
